# LogSage LLM service – copy to .env and fill in your values.
# See README and ROADMAP for provider-specific setup (Bedrock IAM, Vertex SA, etc.).

# Provider: mock | openai | bedrock | gemini
LLM_PROVIDER=mock

# API key (used for openai and gemini when not using Vertex)
LLM_API_KEY=

# ---- OpenAI (LLM_PROVIDER=openai) ----
OPENAI_MODEL_ID=gpt-4o

# ---- AWS Bedrock (LLM_PROVIDER=bedrock) ----
# Uses AWS credentials: AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_REGION
# or IAM role when running on EKS/ECS.
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# ---- Google Gemini (LLM_PROVIDER=gemini) ----
# For AI Studio: set LLM_API_KEY. For Vertex AI: set GOOGLE_APPLICATION_CREDENTIALS (path to SA JSON).
GEMINI_MODEL_ID=gemini-2.0-flash
# Optional for Vertex
# VERTEX_PROJECT_ID=my-gcp-project
# CLOUD_ML_REGION=us-central1

# ---- Server ----
HOST=0.0.0.0
PORT=8000
